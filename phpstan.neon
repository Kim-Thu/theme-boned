parameters:
    level: 1
    paths:
        - .
    excludePaths:
        - vendor/*
        - node_modules/*
        - .github/*
    
    # ✅ Bootstrap WordPress stubs
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    
    # ✅ Ignore errors with exact regex patterns
    ignoreErrors:
        # WordPress core functions/classes not found
        - '#^Function [a-z_]+ not found\.$#i'
        - '#^Class [A-Z][a-zA-Z_]+ not found\.$#i'
        - '#^Method [a-zA-Z_]+::[a-zA-Z_]+\(\) not found\.$#i'
        - '#^Constant [A-Z_]+ not found\.$#i'
        
        # Type hints for WP classes
        - '#^Parameter .+ has invalid type (WP_Post|WP_Query|WP_Term|WP_User)\.$#i'
        - '#^Access to (property|method) .+ on an unknown class (WP_Post|WP_Query|WP_Term|WP_User)\.$#i'
        
        # Generic ignores
        - '#^Variable \$[a-zA-Z_]+ might not be defined\.$#'
        - '#^Access to undefined property#i'
        - '#^Strict comparison#'
        - '#^Unreachable statement#'
        - '#^Comparison operation .+ is always#'
        - '#^Result of .+ is always#'