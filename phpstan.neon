parameters:
    level: 0  # Level thấp nhất để tránh noise từ vendor/
    paths:
        - .
    excludePaths:
        - vendor/*
        - node_modules/*
        - .github/*
        - "*.md"
        - "*.txt"
        - "*.log"
    
    # ✅ Bootstrap WordPress stubs để PHPStan hiểu hàm/class WP
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    
    # ✅ Ignore các lỗi không quan trọng với theme custom
    ignoreErrors:
        # Bỏ qua lỗi reserved keyword (đã fix nhưng cache cũ)
        - '#It is recommended not to use reserved keyword "class" as function parameter name#'
        
        # Bỏ qua lỗi về type WP_Post/WP_Query nếu stubs chưa load kịp
        - '#class WP_Post not found#i'
        - '#class WP_Query not found#i'
        
        # Bỏ qua lỗi về property/method trên class WP_* (do stubs không đầy đủ 100%)
        - '#Access to (property|method) .+ on an unknown class WP_#i'
        
        # Bỏ qua lỗi strict comparison trong vendor/
        - '#Strict comparison .+ will always evaluate to (true|false)#'
        
        # Bỏ qua lỗi unreachable code trong thư viện bên thứ 3
        - '#Unreachable statement#'
        
        # Bỏ qua lỗi về type trong vendor/
        - '#Parameter .+ has invalid type#'
        - '#Return type .+ is not covariant#'